{
  "name": "cross-border-logistics-backend",
  "version": "1.0.0",
  "description": "Cross-border logistics management system backend",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "test": "jest --config jest.config.json",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.json",
    "test:api": "jest --config jest.api.json",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist coverage",
    "prebuild": "npm run clean",
    "postbuild": "cp -r src/templates dist/templates || true",
    "docs:generate": "typedoc --out docs/api src/index.ts src/**/*.ts",
    "migration:generate": "typeorm migration:generate -n",
    "migration:run": "typeorm migration:run",
    "migration:revert": "typeorm migration:revert",
    "seed": "ts-node src/seeds/index.ts",
    "docker:build": "docker build -t cross-border-logistics-backend .",
    "docker:run": "docker run -p 3000:3000 cross-border-logistics-backend"
  },
  "keywords": [
    "logistics",
    "cross-border",
    "shipping",
    "e-commerce",
    "api"
  ],
  "author": "Cross-border Logistics Team",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^6.10.0",
    "express-validator": "^7.0.1",
    "winston": "^3.10.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "mongoose": "^7.4.0",
    "redis": "^4.6.8",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.1",
    "bcryptjs": "^2.4.3",
    "crypto-js": "^4.1.1",
    "axios": "^1.5.0",
    "node-cache": "^5.1.2",
    "bull": "^4.11.2",
    "bull-board": "^4.2.0",
    "socket.io": "^4.6.1",
    "swagger-ui-express": "^5.0.0",
    "yaml": "^2.3.3",
    "typeorm": "^0.3.17",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1",
    "reflect-metadata": "^0.1.13",
    "uuid": "^9.0.0",
    "date-fns": "^2.30.0",
    "lodash": "^4.17.21",
    "joi": "^17.9.2",
    "multer": "^1.4.5-lts.1",
    "express-fileupload": "^1.4.0",
    "qrcode": "^1.5.3",
    "wechat-crypto": "^1.0.0",
    "xml2js": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.5.0",
    "@types/express": "^4.17.17",
    "@types/cors": "^2.8.13",
    "@types/compression": "^1.7.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/bcryptjs": "^2.4.2",
    "@types/crypto-js": "^4.1.1",
    "@types/multer": "^1.4.7",
    "@types/uuid": "^9.0.2",
    "@types/lodash": "^4.14.197",
    "@types/jest": "^29.5.4",
    "@types/supertest": "^2.0.12",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "eslint": "^8.47.0",
    "@typescript-eslint/eslint-plugin": "^6.4.0",
    "@typescript-eslint/parser": "^6.4.0",
    "prettier": "^3.0.2",
    "jest": "^29.6.4",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "faker": "^5.5.3",
    "typedoc": "^0.25.2",
    "@types/mocha": "^10.0.1",
    "@types/swagger-ui-express": "^4.1.3",
    "cross-env": "^7.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/cross-border-logistics.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/cross-border-logistics/issues"
  },
  "homepage": "https://github.com/your-org/cross-border-logistics#readme"
}