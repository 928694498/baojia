# ============================================
# 跨境物流管理系统 - 环境变量配置
# ============================================

# 应用环境
NODE_ENV=production

# ============ 数据库配置 ============
# MongoDB
MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=your-mongodb-root-password
MONGO_USER=logistics_user
MONGO_PASSWORD=your-mongodb-password
MONGO_DATABASE=logistics

# Redis
REDIS_PASSWORD=your-redis-password

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your-rabbitmq-password
RABBITMQ_VHOST=/

# ============ 应用配置 ============
# JWT认证
JWT_SECRET=your-jwt-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# API配置
API_RATE_LIMIT=100
CORS_ORIGIN=http://localhost:3001,http://localhost:3000

# 文件上传
MAX_FILE_SIZE=10mb
UPLOAD_DIR=./uploads

# ============ 企业微信配置 ============
WECHAT_CORP_ID=your-corp-id
WECHAT_AGENT_ID=your-agent-id
WECHAT_SECRET=your-agent-secret
WECHAT_TOKEN=your-token
WECHAT_ENCODING_AES_KEY=your-encoding-aes-key
WECHAT_CALLBACK_URL=http://your-domain.com/wechat/callback

# ============ 邮件服务配置 ============
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-email-password
SMTP_FROM=noreply@your-domain.com

# ============ 第三方API配置 ============
# 物流API
DHL_API_KEY=your-dhl-api-key
FEDEX_API_KEY=your-fedex-api-key
UPS_API_KEY=your-ups-api-key

# 支付网关
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
STRIPE_SECRET_KEY=your-stripe-secret-key

# 地图服务
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
BAIDU_MAPS_API_KEY=your-baidu-maps-api-key

# ============ 监控配置 ============
# Grafana
GRAFANA_PASSWORD=admin

# Sentry (错误监控)
SENTRY_DSN=your-sentry-dsn

# ============ 前端配置 ============
VITE_API_URL=http://localhost:3000
VITE_WEBSOCKET_URL=ws://localhost:3000
VITE_WECHAT_BOT_URL=http://localhost:3002
VITE_GA_TRACKING_ID=your-ga-tracking-id
VITE_SENTRY_DSN=your-sentry-dsn

# ============ 部署配置 ============
# Docker Registry
DOCKER_REGISTRY=ghcr.io
DOCKER_USERNAME=your-username
DOCKER_PASSWORD=your-password

# Kubernetes
KUBE_CONFIG_PATH=~/.kube/config
KUBE_NAMESPACE=logistics-production

# ============ 开发环境覆盖 ============
# 如果要覆盖开发环境的值，创建 .env.development 文件
# 例如：
# NODE_ENV=development
# MONGO_URI=mongodb://localhost:27017/logistics_dev