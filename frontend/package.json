{
  "name": "cross-border-logistics-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "Cross-border logistics management system frontend",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:watch": "tsc --watch",
    "preview": "vite preview",
    "preview:prod": "vite preview --host",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,scss}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,scss}\"",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist node_modules/.vite",
    "prebuild": "npm run clean",
    "docker:build": "docker build -t cross-border-logistics-frontend .",
    "docker:run": "docker run -p 3001:80 cross-border-logistics-frontend"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.2",
    "antd": "^5.10.0",
    "@ant-design/icons": "^5.3.0",
    "@ant-design/charts": "^2.0.0",
    "axios": "^1.5.0",
    "zustand": "^4.4.1",
    "dayjs": "^1.11.10",
    "lodash": "^4.17.21",
    "clsx": "^2.0.0",
    "react-hook-form": "^7.45.4",
    "zod": "^3.22.2",
    "@hookform/resolvers": "^3.3.0",
    "react-query": "^3.39.3",
    "recharts": "^2.9.3",
    "react-hot-toast": "^2.4.1",
    "react-intl": "^6.4.4",
    "react-helmet-async": "^2.0.4",
    "react-error-boundary": "^4.0.11",
    "react-ga4": "^2.1.0",
    "socket.io-client": "^4.6.1",
    "qrcode.react": "^3.1.0",
    "file-saver": "^2.0.5",
    "xlsx": "^0.18.5",
    "js-cookie": "^3.0.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.3",
    "@vitest/ui": "^0.34.2",
    "autoprefixer": "^10.4.15",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "postcss": "^8.4.28",
    "prettier": "^3.0.2",
    "tailwindcss": "^3.3.3",
    "typescript": "^5.0.2",
    "vite": "^4.4.5",
    "vitest": "^0.34.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/your-org/cross-border-logistics.git"
  },
  "bugs": {
    "url": "https://github.com/your-org/cross-border-logistics/issues"
  },
  "homepage": "https://github.com/your-org/cross-border-logistics#readme"
}